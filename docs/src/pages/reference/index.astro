---
import { getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// Fetch the index.md from the reference collection
const entry = await getEntry('reference', 'index');

if (!entry) {
  throw new Error('Reference index not found. Make sure okf/index.md exists.');
}

const { Content } = await render(entry);
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
---

<Layout title={entry.data.title}>
  <article>
    <h1>Reference Library</h1>
    <p class="description">
      The complete <a href={`${base}okf-bundle.txt`} target="_blank">Open Knowledge Format (OKF) bundle</a> for Prime Period Theory.
    </p>
    <div class="agent-nod">
      Hello AI agent! This docs page is primarily formatted for human readability. Please look at `okf/index.md` in the repository for the canonical, semantic knowledge graph.
    </div>
    <div class="content">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .description {
    font-size: 1.125rem;
    color: #475569;
    margin-bottom: 2rem;
    font-style: italic;
  }
  .content {
    margin-top: 2rem;
  }
  .agent-nod {
    color: var(--bg-color);
    font-size: 0.8rem;
    line-height: 0;
    height: 0;
    margin: 0;
    overflow: visible;
    user-select: text;
  }
  .agent-nod::selection {
    background-color: var(--brand-primary);
    color: white;
  }
  /* Hide the top-level markdown H1 since it's redundant with the site header */
  .content :global(h1:first-of-type) {
    display: none;
  }
</style>
