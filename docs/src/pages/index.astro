---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const referenceEntries = await getCollection('reference');
const topicEntries = await getCollection('topics');
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
---

<Layout title="Home">
  <h1>Prime Period Theory Documentation</h1>
  <p>Welcome to the compiled documentation for Prime Period Theory (PPT). This site serves three primary purposes:</p>
  
  <div class="grid">
    <div class="card">
      <h2>1. A Perspective on Music</h2>
      <p>PPT offers a descriptive framework to analyze and conceptualize music, treating pitch, rhythm, and timbre as unified expressions of prime-generated periodicity.</p>
      <div class="section-links">
        <h3>Curated Topics</h3>
        <ul>
          {topicEntries.map(topic => (
            <li>
              <a href={`${base}topics/${topic.id}`}>{topic.data.title}</a>
            </li>
          ))}
        </ul>
        {topicEntries.length === 0 && <p><em>No topics generated yet.</em></p>}
      </div>
    </div>

    <div class="card">
      <h2>2. Interactive Components</h2>
      <p>Interactable music reference tools that bring PPT to life. These components are used throughout the documentation to demonstrate theoretical concepts, but are also independently usable by anyone who wants to integrate them into their own projects.</p>
    </div>

    <div class="card">
      <h2>3. OKF Knowledge Library</h2>
      <p>An agent and human-readable knowledge bundle structured in the Open Knowledge Format (OKF). Referencing standards like Karpathy's <code>llms.txt</code> and Google's Open Knowledge Format, this semantic core is browsable as raw concepts or easily importable into any LLM conversation context.</p>
      <div class="section-links">
        <h3>Reference Knowledge</h3>
        <ul>
          {referenceEntries.map(ref => (
            <li>
              <a href={`${base}reference/${ref.id === 'index' ? '' : ref.id}`}>{ref.data.title}</a>
            </li>
          ))}
        </ul>
        {referenceEntries.length === 0 && <p><em>No reference entries found.</em></p>}
      </div>
    </div>
  </div>
</Layout>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }
  @media (min-width: 768px) {
    .grid {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    }
  }
  @media (min-width: 1200px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .card {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    border: 1px solid #e2e8f0;
    display: flex;
    flex-direction: column;
  }
  .card h2 {
    margin-top: 0;
    font-size: 1.25rem;
    color: #1a202c;
  }
  .card h3 {
    font-size: 1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: #4a5568;
    border-bottom: 1px solid #e2e8f0;
    padding-bottom: 0.25rem;
  }
  .card p {
    color: #4a5568;
    line-height: 1.5;
  }
  .section-links {
    margin-top: auto;
  }
  .section-links ul {
    margin: 0;
    padding-left: 1.5rem;
  }
</style>
