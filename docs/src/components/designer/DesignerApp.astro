---
import { getPPTComponents } from './parseComponents.js';

const components = getPPTComponents();
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
---

<div class="designer-app" id="designer-app" data-split="50">
  
  <!-- Header / Toolbar -->
  <div class="designer-toolbar">
    <div class="toolbar-left" style="display: flex; align-items: center; gap: 8px; padding-left: 8px;">
      <a href={base} style="display: flex; align-items: center; text-decoration: none; padding-right: 4px;" title="Back to Prime Period Theory">
        <img src={`${base}logo.svg`} alt="Prime Period Theory" style="height: 24px; width: auto;" />
      </a>
      <span style="font-weight: 600; font-size: 15px; color: #fff;">Component Composer</span>
    </div>
    <div class="toolbar-center">
      <span class="toolbar-label">Layout Split:</span>
      <button class="toolbar-btn layout-btn active" data-ratio="75" title="Designer Focused">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><rect x="2" y="4" width="14" height="16" rx="2"></rect><rect x="18" y="4" width="4" height="16" rx="1"></rect></svg>
      </button>
      <button class="toolbar-btn layout-btn" data-ratio="50" title="Split 50/50">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><rect x="2" y="4" width="9" height="16" rx="2"></rect><rect x="13" y="4" width="9" height="16" rx="2"></rect></svg>
      </button>
      <button class="toolbar-btn layout-btn" data-ratio="25" title="Preview Focused">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><rect x="2" y="4" width="4" height="16" rx="1"></rect><rect x="8" y="4" width="14" height="16" rx="2"></rect></svg>
      </button>
      <button class="toolbar-btn layout-btn" data-ratio="0" title="Preview Only">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg>
      </button>
      <div style="width: 1px; height: 20px; background: #555; margin: 0 8px;"></div>
      <button id="btn-load-payload" class="toolbar-btn" style="padding: 2px 12px; font-weight: 500;">
        Load Payload
      </button>
    </div>
  </div>

  <!-- Main Grid -->
  <div class="designer-grid">
    <!-- Left Pane -->
    <div class="left-pane">
      <div class="pane pane-tree">
        <div class="pane-header" style="display: flex; justify-content: space-between; align-items: center;">
          <span>Component Tree</span>
          <button id="btn-toggle-library" class="toolbar-btn" style="padding: 2px 8px; font-size: 11px; height: 22px;">
            <svg viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" stroke-width="2" fill="none" style="margin-right: 4px;"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>
            Library
          </button>
        </div>
        <div class="pane-content tree-view" id="dom-tree">
          <!-- Tree populated dynamically -->
        </div>
      </div>
      <div class="pane pane-props">
        <div class="pane-header">Properties</div>
        <div class="pane-content" id="properties-panel">
          <p class="empty-state">Select a component to edit its properties.</p>
        </div>
      </div>
    </div>
    
    <!-- Right Pane (Canvas) -->
    <div class="right-pane pane pane-center">
      <div class="pane-header">Preview</div>
      <div class="canvas-wrapper" id="canvas-wrapper">
        <div class="canvas" id="canvas">
          <ppt-container id="demo-container" resizable="true" style="width: 400px; height: 400px;">
            <ppt-period id="demo-period" shape="circle" interactive="true" min-width="200" min-height="200">
              <ppt-period-step-circle slot="step">A</ppt-period-step-circle>
              <ppt-period-step-circle slot="step">B</ppt-period-step-circle>
              <ppt-period-step-circle slot="step">C</ppt-period-step-circle>
            </ppt-period>
          </ppt-container>
        </div>
      </div>
    </div>
  </div>

  <div class="resizer-horizontal" id="resizer-bottom"></div>
  <!-- Bottom Pane (Code) -->
  <footer class="pane pane-bottom" id="pane-bottom">
    <div class="pane-header" style="display: flex; justify-content: space-between; align-items: center; cursor: pointer; user-select: none;" id="btn-toggle-code">
      <span style="display: flex; align-items: center; gap: 6px;">
        <svg id="icon-collapse-code" viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" style="transition: transform 0.2s;"><polyline points="6 9 12 15 18 9"></polyline></svg>
        Source Code
      </span>
      <div style="display: flex; gap: 8px;" onclick="event.stopPropagation()">
        <button id="btn-copy-html" class="toolbar-btn" style="padding: 2px 8px; font-size: 11px; height: 22px;">Copy HTML</button>
        <button id="btn-copy-payload" class="toolbar-btn" style="padding: 2px 8px; font-size: 11px; height: 22px;">Copy Payload</button>
      </div>
    </div>
    <div class="pane-content">
      <pre><code id="source-code"></code></pre>
    </div>
  </footer>
  
  <!-- Library Drawer -->
  <div class="library-drawer" id="library-drawer">
    <div class="drawer-header">
      Component Library
      <button id="btn-close-library" class="close-btn">&times;</button>
    </div>
    <div class="drawer-content">
      <p class="drawer-help">Drag components into the Canvas or DOM Tree.</p>
      <ul class="component-library" id="library-list">
        {components.map(comp => {
          const getConstraintBg = (constraints: string[]) => {
            if (!constraints || constraints.length === 0) return 'dashed';
            if (constraints.includes('*')) return '#888';
            const colors = constraints.map((tag: string) => {
              const c = components.find(x => x.tagName === tag);
              return c?.componentDef?.familyColor || '#888';
            });
            if (colors.length === 1) return colors[0];
            return `linear-gradient(to bottom, ${colors.join(', ')})`;
          };
          const parentBg = getConstraintBg(comp.componentDef?.canNestIn || []);
          const childBg = getConstraintBg(comp.componentDef?.acceptsChildren || []);
          const isContainer = comp.tagName === 'ppt-container';

          return (
            <li class="library-item" draggable="true" 
                style={isContainer ? 'display: none;' : ''}
                data-tag={comp.tagName} 
                data-attributes={JSON.stringify(comp.attributes || [])}
                data-metadata={JSON.stringify(comp.metadata || {})}
                data-component-def={JSON.stringify(comp.componentDef || {})}>
              <div class={`constraint-left ${parentBg === 'dashed' ? 'constraint-dashed' : ''}`} style={parentBg !== 'dashed' ? `background: ${parentBg};` : ''} title={`Nests in: ${comp.componentDef?.canNestIn?.join(', ')}`}></div>
              
              <div class="library-item-content" style="display: flex; align-items: center; justify-content: space-between;">
                <div style="display: flex; align-items: center;">
                  <span class="color-swatch" style={`background-color: ${comp.componentDef?.familyColor || '#888'}; width: 10px; height: 10px; display: inline-block; margin-right: 8px; border-radius: 2px;`}></span>
                  <span class="display-name" style="font-weight: bold; color: #fff;">{comp.componentDef?.displayName || comp.tagName}</span>
                </div>
              </div>
              
              <div class={`constraint-right ${childBg === 'dashed' ? 'constraint-dashed' : ''}`} style={childBg !== 'dashed' ? `background: ${childBg};` : ''} title={`Accepts: ${comp.componentDef?.acceptsChildren?.join(', ')}`}></div>
            </li>
          );
        })}
      </ul>
    </div>
  </div>
  <div class="drawer-overlay" id="drawer-overlay"></div>
  
  <div class="context-menu" id="add-child-menu">
    <!-- Populated dynamically -->
  </div>
</div>

<script>
  import '../../../components/src/index.js';

  // State
  let selectedElement: HTMLElement | null = null;
  const canvas = document.getElementById('canvas');
  const domTree = document.getElementById('dom-tree');
  const propertiesPanel = document.getElementById('properties-panel');
  const sourceCode = document.getElementById('source-code');
  const libraryItems = document.querySelectorAll('.library-item');
  
  // Tree expanded state tracking
  const expandedNodes = new Set<string>();

  // Constraint Helpers
  function getComponentDef(tagName: string) {
    if (!tagName) return null;
    const libItem = document.querySelector(`.library-item[data-tag="${tagName.toLowerCase()}"]`);
    if (libItem) {
      const defStr = libItem.getAttribute('data-component-def');
      if (defStr) {
         try { return JSON.parse(defStr); } catch(e){}
      }
    }
    return null;
  }
  
  function isValidDrop(parentTag: string, childTag: string) {
    const parentDef = getComponentDef(parentTag);
    const childDef = getComponentDef(childTag);
    
    if (parentDef) {
       if (parentDef.acceptsChildren.length === 0) return false;
       if (!parentDef.acceptsChildren.includes('*') && !parentDef.acceptsChildren.includes(childTag)) return false;
    }
    if (childDef) {
       if (childDef.canNestIn.length === 0) return false;
       if (!childDef.canNestIn.includes('*') && !childDef.canNestIn.includes(parentTag)) return false;
    }
    return true;
  }

  // Context Menu
  const contextMenu = document.getElementById('add-child-menu');

  document.addEventListener('click', (e) => {
    if (contextMenu && !contextMenu.contains(e.target as Node)) {
      contextMenu.classList.remove('show');
    }
  });

  function showContextMenu(x: number, y: number, targetNode: HTMLElement) {
    if (!contextMenu || !targetNode) return;
    contextMenu.innerHTML = '';
    
    const parentTag = targetNode.tagName.toLowerCase();
    const validChildren: any[] = [];
    
    libraryItems.forEach(item => {
      const childTag = item.getAttribute('data-tag');
      if (childTag === 'ppt-container') return;
      if (childTag && isValidDrop(parentTag, childTag)) {
        const defStr = item.getAttribute('data-component-def');
        let displayName = childTag;
        let color = '#888';
        if (defStr) {
           try { 
             const def = JSON.parse(defStr);
             displayName = def.displayName || childTag;
             color = def.familyColor || color;
           } catch(e){}
        }
        validChildren.push({ tag: childTag, displayName, color });
      }
    });
    
    if (validChildren.length === 0) {
       contextMenu.innerHTML = `<div class="context-menu-empty">No valid children</div>`;
    } else {
       validChildren.forEach(child => {
          const div = document.createElement('div');
          div.className = 'context-menu-item';
          div.innerHTML = `<span class="color-swatch" style="background-color: ${child.color}; width: 10px; height: 10px; display: inline-block; border-radius: 2px;"></span>${child.displayName}`;
          div.addEventListener('click', () => {
             const newEl = document.createElement(child.tag);
             if (child.tag === 'ppt-period-step-circle' && targetNode.tagName.toLowerCase().includes('ppt-')) {
               newEl.setAttribute('slot', 'step');
             }
             targetNode.appendChild(newEl);
             // Auto-expand the parent we dropped into
             const pathStr = targetNode.getAttribute('data-path') || '[]';
             expandedNodes.add(pathStr);
             selectElement(newEl);
             contextMenu.classList.remove('show');
          });
          contextMenu.appendChild(div);
       });
    }
    
    // Position menu
    contextMenu.style.left = `${x}px`;
    contextMenu.style.top = `${y}px`;
    contextMenu.classList.add('show');
  }

  // Layout Controls
  const designerApp = document.getElementById('designer-app');
  const layoutBtns = document.querySelectorAll('.layout-btn');
  
  // Load split preference from local storage
  const savedSplit = localStorage.getItem('ppt-designer-split') || '75';
  if (designerApp) designerApp.setAttribute('data-split', savedSplit);
  layoutBtns.forEach(btn => {
    if (btn.getAttribute('data-ratio') === savedSplit) {
       layoutBtns.forEach(b => b.classList.remove('active'));
       btn.classList.add('active');
    }
    btn.addEventListener('click', () => {
      layoutBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const ratio = btn.getAttribute('data-ratio');
      if (designerApp && ratio) {
        designerApp.setAttribute('data-split', ratio);
        localStorage.setItem('ppt-designer-split', ratio);
      }
    });
  });

  // Drawer Controls
  const libraryDrawer = document.getElementById('library-drawer');
  const drawerOverlay = document.getElementById('drawer-overlay');
  const btnToggleLibrary = document.getElementById('btn-toggle-library');
  const btnCloseLibrary = document.getElementById('btn-close-library');

  function toggleDrawer(force?: boolean) {
    const isOpen = libraryDrawer?.classList.contains('open');
    if (force === true || (!isOpen && force !== false)) {
      libraryDrawer?.classList.add('open');
      drawerOverlay?.classList.add('open');
    } else {
      libraryDrawer?.classList.remove('open');
      drawerOverlay?.classList.remove('open');
    }
  }

  btnToggleLibrary?.addEventListener('click', () => toggleDrawer());
  btnCloseLibrary?.addEventListener('click', () => toggleDrawer(false));
  drawerOverlay?.addEventListener('click', () => toggleDrawer(false));

  // Bottom Pane Controls
  const paneBottom = document.getElementById('pane-bottom');
  const resizerBottom = document.getElementById('resizer-bottom');
  const btnToggleCode = document.getElementById('btn-toggle-code');
  const iconCollapseCode = document.getElementById('icon-collapse-code');
  let isResizingBottom = false;

  btnToggleCode?.addEventListener('click', () => {
    paneBottom?.classList.toggle('collapsed');
    if (paneBottom?.classList.contains('collapsed')) {
      if (iconCollapseCode) iconCollapseCode.style.transform = 'rotate(-90deg)';
    } else {
      if (iconCollapseCode) iconCollapseCode.style.transform = 'rotate(0deg)';
    }
  });

  resizerBottom?.addEventListener('mousedown', (e) => {
    e.preventDefault();
    isResizingBottom = true;
    document.body.style.cursor = 'row-resize';
    resizerBottom.classList.add('active');
  });

  document.addEventListener('mousemove', (e) => {
    if (!isResizingBottom || !paneBottom) return;
    paneBottom.classList.remove('collapsed');
    if (iconCollapseCode) iconCollapseCode.style.transform = 'rotate(0deg)';
    const offsetBottom = document.body.offsetHeight - e.clientY;
    paneBottom.style.height = `${Math.max(40, offsetBottom)}px`;
  });

  document.addEventListener('mouseup', () => {
    isResizingBottom = false;
    document.body.style.cursor = '';
    resizerBottom?.classList.remove('active');
  });

  // Source Code Formatting
  function formatHTML(htmlStr: string) {
    let formatted = '';
    let indent = 0;
    const tab = '  ';
    htmlStr = htmlStr.replace(/\n/g, '').replace(/>\s*</g, '><');
    htmlStr.split(/(<\/?[^>]+>)/g).forEach(node => {
      if (!node.trim()) return;
      if (node.match(/^\s*<\//)) {
        indent--;
        formatted += tab.repeat(Math.max(0, indent)) + node + '\n';
      } else if (node.match(/^\s*<[^/]/)) {
        formatted += tab.repeat(Math.max(0, indent)) + node + '\n';
        if (!node.match(/\/>$/) && !node.match(new RegExp('</.*>'))) indent++;
      } else {
        formatted += tab.repeat(Math.max(0, indent)) + node.trim() + '\n';
      }
    });
    return formatted.trim();
  }

  function highlightHTML(htmlStr: string) {
    return htmlStr
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/([a-zA-Z0-9-]+)(=)("[^"]*")/g, '<span class="hl-attr">$1</span>$2<span class="hl-val">$3</span>')
      .replace(/(&lt;\/?)([a-zA-Z0-9-]+)/g, '$1<span class="hl-tag">$2</span>')
      .replace(/(&lt;!--[\\s\\S]*?--&gt;)/g, '<span class="hl-comment">$1</span>');
  }

  function generateCleanHTML(node: Element): string {
    let html = '';
    Array.from(node.children).forEach(child => {
      let tag = child.tagName.toLowerCase();
      if (!tag.startsWith('ppt-')) return;
      
      let attrStr = '';
      const libItem = document.querySelector(`.library-item[data-tag="${tag}"]`);
      let meta: Record<string, any> = {};
      if (libItem) {
        meta = JSON.parse(libItem.getAttribute('data-metadata') || '{}');
      }
      
      Array.from(child.attributes).forEach(attr => {
         const name = attr.name;
         if (['class', 'draggable'].includes(name) || name.startsWith('data-astro-cid') || name === 'id') return;
         
         let val = attr.value;
         if (name === 'style') {
             let elStyle = (child as HTMLElement).style;
             let styleStr = '';
             if (elStyle.width) styleStr += `width: ${elStyle.width}; `;
             if (elStyle.height) styleStr += `height: ${elStyle.height}; `;
             if (elStyle.flex) styleStr += `flex: ${elStyle.flex}; `;
             if (!styleStr.trim()) return;
             val = styleStr.trim();
         }
         
         const m = meta[name];
         if (m && m.default !== undefined) {
            if (String(m.default) === val || (m.type === 'boolean' && val === 'true' && m.default === true)) return;
         }
         attrStr += ` ${name}="${val}"`;
      });
      
      let inner = '';
      if (child.children.length > 0) {
          inner = generateCleanHTML(child);
      } else if (child.textContent && child.textContent.trim()) {
          inner = child.textContent.trim();
      }
      
      html += `<${tag}${attrStr}>${inner}</${tag}>`;
    });
    return html;
  }

  // Sync Code
  function syncCode() {
    if (!canvas || !sourceCode) return;
    let cleanHTML = generateCleanHTML(canvas);
    let formatted = formatHTML(cleanHTML);
    sourceCode.innerHTML = highlightHTML(formatted);
  }

  // Copy Handlers
  document.getElementById('btn-copy-html')?.addEventListener('click', () => {
    if (canvas) {
      navigator.clipboard.writeText(formatHTML(generateCleanHTML(canvas)));
      alert('HTML copied to clipboard!');
    }
  });

  function serializePayload(rootEl: HTMLElement): string {
    let componentsUsed = new Set<string>();
    let idCounter = 0;
    
    function gatherTags(node: Element) {
      if (node.tagName && node.tagName.toLowerCase().startsWith('ppt-')) {
        componentsUsed.add(node.tagName.toLowerCase());
      }
      for (let child of Array.from(node.children)) gatherTags(child);
    }
    gatherTags(rootEl);
    
    let tagToChar: Record<string, string> = {};
    let charToTag: Record<string, string> = {};
    let charCode = 65; // 'A'
    Array.from(componentsUsed).sort().forEach(tag => {
      let char = String.fromCharCode(charCode++);
      tagToChar[tag] = char;
      charToTag[char] = tag;
    });
    
    let headerStr = Object.entries(charToTag).map(([char, tag]) => `${char}:${tag}`).join(',');
    
    let attrMap: string[] = [];
    let instanceIndex = 0;
    
    function buildNode(node: Element): string {
      if (node.tagName && node.tagName.toLowerCase().startsWith('ppt-')) {
        let tag = node.tagName.toLowerCase();
        let char = tagToChar[tag];
        
        let overrides: Record<string, string> = {};
        const libItem = document.querySelector(`.library-item[data-tag="${tag}"]`);
        let meta: Record<string, any> = {};
        if (libItem) {
          meta = JSON.parse(libItem.getAttribute('data-metadata') || '{}');
        }
        
        Array.from(node.attributes).forEach(attr => {
           if (['id', 'class', 'draggable'].includes(attr.name)) return;
           if (attr.name === 'style') {
               let elStyle = (node as HTMLElement).style;
               let styleStr = '';
               if (elStyle.width) styleStr += `width: ${elStyle.width}; `;
               if (elStyle.height) styleStr += `height: ${elStyle.height}; `;
               if (elStyle.flex) styleStr += `flex: ${elStyle.flex}; `;
               if (styleStr.trim()) overrides['style'] = styleStr.trim();
               return;
           }
           const val = attr.value;
           const m = meta[attr.name];
           if (m && m.default !== undefined) {
              if (String(m.default) === val || (m.type === 'boolean' && val === 'true' && m.default === true)) return;
           }
           overrides[attr.name] = val;
        });
        
        if (node.textContent && node.textContent.trim() && node.children.length === 0) {
           overrides['textContent'] = node.textContent.trim();
        }
        
        if (Object.keys(overrides).length > 0) {
           let attrStr = Object.entries(overrides).map(([k,v]) => `${k}:${encodeURIComponent(v)}`).join(',');
           attrMap.push(`${instanceIndex}:{${attrStr}}`);
        }
        
        instanceIndex++;
        
        let childrenStr = '';
        if (node.children.length > 0) {
           let childParts: string[] = [];
           for (let child of Array.from(node.children)) {
              let childStr = buildNode(child);
              if (childStr) childParts.push(childStr);
           }
           if (childParts.length > 0) childrenStr = `[${childParts.join(',')}]`;
        }
        return `${char}${childrenStr}`;
      }
      return '';
    }
    
    let structureStr = Array.from(rootEl.children).map(c => buildNode(c)).filter(Boolean).join(',');
    let attrStr = attrMap.join(',');
    
    return `${headerStr}|${attrStr}|${structureStr}`;
  }

  function deserializePayload(rawPayload: string, targetEl: HTMLElement) {
    if (!rawPayload) return;
    const parts = rawPayload.split('|');
    if (parts.length !== 3) return;
    const [headerStr, attrStr, structureStr] = parts;
    
    const charToTag: Record<string, string> = {};
    headerStr.split(',').forEach(part => {
       const [char, tag] = part.split(':');
       if (char && tag) charToTag[char] = tag;
    });
    
    const attrOverrides: Record<string, Record<string, string>> = {};
    if (attrStr) {
        const regex = /(\d+):{([^}]+)}/g;
        let match;
        while ((match = regex.exec(attrStr)) !== null) {
            const idx = match[1];
            const propsStr = match[2];
            const props: Record<string, string> = {};
            propsStr.split(',').forEach(p => {
                const [k, v] = p.split(':');
                props[k] = decodeURIComponent(v);
            });
            attrOverrides[idx] = props;
        }
    }
    
    let currentIdx = 0;
    
    function parseStructure(str: string) {
       let currentContainer: any = { children: [] };
       let stack: any[] = [currentContainer];
       let i = 0;
       
       while (i < str.length) {
          const char = str[i];
          if (charToTag[char]) {
             let node = { tag: charToTag[char], idx: currentIdx++, children: [] };
             stack[stack.length - 1].children.push(node);
             if (i + 1 < str.length && str[i+1] === '[') {
                 stack.push(node);
                 i++;
             }
          } else if (char === ']') {
             stack.pop();
          }
          i++;
       }
       return currentContainer.children;
    }
    
    function buildDOM(nodes: any[]) {
       let frag = document.createDocumentFragment();
       nodes.forEach(n => {
           let el = document.createElement(n.tag);
           if (attrOverrides[n.idx]) {
               for (let [k, v] of Object.entries(attrOverrides[n.idx])) {
                   if (k === 'textContent') el.textContent = v as string;
                   else el.setAttribute(k, v as string);
               }
           }
           if (n.children.length > 0) {
               el.appendChild(buildDOM(n.children));
           }
           frag.appendChild(el);
       });
       return frag;
    }
    
    const nodes = parseStructure(structureStr);
    targetEl.innerHTML = '';
    targetEl.appendChild(buildDOM(nodes));
  }

  // Compression Utilities
  async function compressPayload(text: string): Promise<string> {
    if (typeof CompressionStream === 'undefined') return 'raw:' + text; // Fallback
    const stream = new Blob([text]).stream().pipeThrough(new CompressionStream('deflate'));
    const compressedResponse = await new Response(stream).arrayBuffer();
    const uint8Array = new Uint8Array(compressedResponse);
    // Convert to base64
    let binary = '';
    for (let i = 0; i < uint8Array.byteLength; i++) {
      binary += String.fromCharCode(uint8Array[i]);
    }
    return 'gz:' + btoa(binary);
  }

  async function decompressPayload(payload: string): Promise<string> {
    if (payload.startsWith('raw:')) return payload.substring(4);
    if (!payload.startsWith('gz:')) {
       // Auto-detect: if it has pipes, it's raw
       if (payload.includes('|')) return payload;
       return payload; // Unknown format
    }
    
    const base64 = payload.substring(3);
    const binaryStr = atob(base64);
    const uint8Array = new Uint8Array(binaryStr.length);
    for (let i = 0; i < binaryStr.length; i++) {
       uint8Array[i] = binaryStr.charCodeAt(i);
    }
    
    if (typeof DecompressionStream === 'undefined') throw new Error("DecompressionStream not supported");
    const stream = new Blob([uint8Array]).stream().pipeThrough(new DecompressionStream('deflate'));
    return await new Response(stream).text();
  }

  document.getElementById('btn-copy-payload')?.addEventListener('click', async () => {
    if (canvas) {
      const rawPayload = serializePayload(canvas);
      const compressedPayload = await compressPayload(rawPayload);
      navigator.clipboard.writeText(compressedPayload);
      alert('Composition payload copied to clipboard!');
    }
  });

  document.getElementById('btn-load-payload')?.addEventListener('click', () => {
    const payload = prompt("Paste your Composition Payload:");
    if (payload && payload.trim()) {
      const url = new URL(window.location.href);
      url.searchParams.set('payload', payload.trim());
      window.location.href = url.toString();
    }
  });
  
  // On load, check for payload
  window.addEventListener('DOMContentLoaded', async () => {
    const params = new URLSearchParams(window.location.search);
    let payload = params.get('payload') || params.get('slug'); // Fallback to slug for backward compatibility
    if (payload && canvas) {
      try {
        const rawPayload = await decompressPayload(payload);
        deserializePayload(rawPayload, canvas);
      } catch (e) {
        console.error("Failed to decompress or parse payload", e);
      }
    }
  });

  // MutationObserver
  if (canvas) {
    const observer = new MutationObserver(() => {
      syncCode();
      renderTree();
    });
    observer.observe(canvas, { childList: true, subtree: true, attributes: true });
    syncCode();
    renderTree();
  }

  // Remove click listener from Canvas
  // Canvas should not be interactive in terms of selection
  // Handling selection only via Tree or library drag.

  function selectElement(el: HTMLElement | null) {
    if (selectedElement) {
      selectedElement.classList.remove('designer-selected');
    }
    selectedElement = el;
    
    if (selectedElement) {
      selectedElement.classList.add('designer-selected');
      // Ensure path to selected element is expanded
      expandPathToSelected(selectedElement);
      renderProperties(selectedElement);
    } else {
      renderProperties(null);
    }
    renderTree();
  }

  function expandPathToSelected(el: HTMLElement) {
    // Basic traversal up to canvas to add all paths to expandedNodes
    let path: number[] = [];
    let current = el;
    while (current && current.parentElement && current !== canvas) {
      const siblings = Array.from(current.parentElement.children);
      path.unshift(siblings.indexOf(current));
      current = current.parentElement;
    }
    
    // Now incrementally build paths from root and expand them
    let runningPath: number[] = [];
    for (let idx of path) {
       expandedNodes.add(JSON.stringify(runningPath));
       runningPath.push(idx);
    }
  }

  // Render Properties
  function renderProperties(el: HTMLElement | null) {
    if (!propertiesPanel) return;
    if (!el) {
      propertiesPanel.innerHTML = '<p class="empty-state">Select a component to edit its properties.</p>';
      return;
    }

    const tagName = el.tagName.toLowerCase();
    let allowedAttrs: string[] = [];
    let metadata: Record<string, any> = {};
    let componentDef: Record<string, any> = {};
    const libItem = document.querySelector(`.library-item[data-tag="${tagName}"]`);
    if (libItem) {
      allowedAttrs = JSON.parse(libItem.getAttribute('data-attributes') || '[]');
      metadata = JSON.parse(libItem.getAttribute('data-metadata') || '{}');
      componentDef = JSON.parse(libItem.getAttribute('data-component-def') || '{}');
    }

    // Filter out standard HTML attributes as requested
    const filteredAttrs = allowedAttrs.filter(a => !['id', 'class', 'style', 'slot'].includes(a));
    if (metadata['textContent']) {
      filteredAttrs.push('textContent');
    }

    // Sort textContent to the end for better UX
    filteredAttrs.sort((a, b) => {
      if (a === 'textContent') return 1;
      if (b === 'textContent') return -1;
      return 0;
    });

    let html = `<div class="prop-form">`;
    filteredAttrs.forEach(attr => {
      let val = el.getAttribute(attr);
      if (attr === 'textContent') {
         val = el.textContent;
      }
      const meta = metadata[attr] || { type: 'string' };
      
      html += `<div class="prop-group">`;
      html += `<div class="prop-control-col">`;
      html += `<label>${attr}</label>`;
      
      if (meta.type === 'boolean') {
        const isChecked = val === 'true' || val === '' || (val === null && meta.default === true);
        html += `<input type="checkbox" data-attr="${attr}" ${isChecked ? 'checked' : ''} />`;
      } else if (meta.type === 'color') {
        const displayVal = val || (meta.default !== undefined ? meta.default : '#ffffff');
        html += `<input type="color" data-attr="${attr}" value="${displayVal}" />`;
      } else if (meta.type === 'enum' && meta.options) {
        html += `<select data-attr="${attr}">`;
        meta.options.forEach((opt: string) => {
          const isSelected = val === opt || (val === null && meta.default === opt);
          html += `<option value="${opt}" ${isSelected ? 'selected' : ''}>${opt}</option>`;
        });
        html += `</select>`;
      } else if (attr === 'textContent') {
        const displayVal = val || (meta.default !== undefined ? meta.default : '');
        html += `<textarea data-attr="${attr}" rows="3" style="width: 100%; resize: vertical;">${String(displayVal).replace(/</g, '&lt;').replace(/>/g, '&gt;')}</textarea>`;
      } else {
        const displayVal = val || (meta.default !== undefined ? meta.default : '');
        html += `<input type="text" data-attr="${attr}" value="${String(displayVal).replace(/"/g, '&quot;')}" />`;
      }
      
      html += `</div>`; // end prop-control-col
      
      html += `<div class="prop-desc-col">`;
      html += meta.description ? meta.description : '';
      html += `</div>`; // end prop-desc-col
      
      html += `</div>`; // end prop-group
    });
    html += '</div>';
    propertiesPanel.innerHTML = html;

    const inputs = propertiesPanel.querySelectorAll('input, select, textarea');
    inputs.forEach(input => {
      input.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
        const attr = target.getAttribute('data-attr');
        if (attr) {
          if (attr === 'textContent') {
             el.textContent = target.value;
             return;
          }
          if (target.type === 'checkbox') {
            const isChecked = (target as HTMLInputElement).checked;
            el.setAttribute(attr, isChecked ? 'true' : 'false');
          } else {
            if (target.value) {
              el.setAttribute(attr, target.value);
            } else {
              el.removeAttribute(attr);
            }
          }
        }
      });
      // Also listen to input for text fields for real-time updates
      if (input.type === 'text' || input.tagName.toLowerCase() === 'textarea') {
        input.addEventListener('input', (e) => {
          const target = e.target as HTMLInputElement | HTMLTextAreaElement;
          const attr = target.getAttribute('data-attr');
          if (attr && attr === 'textContent') {
             el.textContent = target.value;
             return;
          }
          if (attr && target.value) el.setAttribute(attr, target.value);
        });
      }
    });
  }

  // Render DOM Tree
  function renderTree() {
    if (!domTree || !canvas) return;
    domTree.innerHTML = buildTreeHTML(canvas, 0);
    
    // Attach tree node click listeners
    domTree.querySelectorAll('.tree-node-clickable').forEach(node => {
      node.addEventListener('click', (e) => {
        e.stopPropagation();
        const pathStr = node.getAttribute('data-path');
        if (pathStr) {
          const target = getElementByPath(JSON.parse(pathStr));
          if (target) selectElement(target);
        }
      });
      
      // Right-click Context Menu
      node.addEventListener('contextmenu', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const pathStr = node.getAttribute('data-path');
        if (pathStr) {
          const target = getElementByPath(JSON.parse(pathStr));
          if (target) {
            selectElement(target);
            showContextMenu(e.clientX, e.clientY, target);
          }
        }
      });

      // Tree drag and drop to append to node
      node.addEventListener('dragover', (e: any) => {
        if (!draggedTag) return;
        const pathStr = node.getAttribute('data-path');
        const targetParent = pathStr ? getElementByPath(JSON.parse(pathStr)) : null;
        if (targetParent) {
           const parentTag = targetParent.tagName.toLowerCase();
           if (!isValidDrop(parentTag, draggedTag)) return; // Reject drop
        }
        
        e.preventDefault();
        e.dataTransfer.dropEffect = 'copy';
        node.classList.add('drag-over');
      });
      node.addEventListener('dragleave', (e: any) => {
        node.classList.remove('drag-over');
      });
      node.addEventListener('drop', (e: any) => {
        e.preventDefault();
        e.stopPropagation();
        node.classList.remove('drag-over');
        
        const pathStr = node.getAttribute('data-path');
        const targetParent = pathStr ? getElementByPath(JSON.parse(pathStr)) : null;
        
        if (targetParent && draggedTag) {
           const parentTag = targetParent.tagName.toLowerCase();
           if (!isValidDrop(parentTag, draggedTag)) {
             alert(`Cannot nest <${draggedTag}> inside <${parentTag}> based on component constraints.`);
             return;
           }

           const newEl = document.createElement(draggedTag);
           if (draggedTag === 'ppt-period-step-circle' && targetParent.tagName.toLowerCase().includes('ppt-')) {
             newEl.setAttribute('slot', 'step');
           }
           targetParent.appendChild(newEl);
           
           // Auto-expand the parent we dropped into
           expandedNodes.add(pathStr || '[]');
           
           selectElement(newEl);
           draggedTag = null;
        }
      });
    });

    // Attach tree toggle listeners
    domTree.querySelectorAll('.tree-toggle').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const pathStr = btn.getAttribute('data-path');
        if (pathStr) {
          if (expandedNodes.has(pathStr)) {
            expandedNodes.delete(pathStr);
          } else {
            expandedNodes.add(pathStr);
          }
          renderTree();
        }
      });
    });

    // Attach tree controls listeners
    domTree.querySelectorAll('.add-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const rect = btn.getBoundingClientRect();
        if (selectedElement) {
          showContextMenu(rect.left, rect.bottom + 4, selectedElement);
        }
      });
    });

    domTree.querySelectorAll('.up-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (selectedElement && selectedElement.previousElementSibling) {
          selectedElement.parentNode?.insertBefore(selectedElement, selectedElement.previousElementSibling);
        }
      });
    });

    domTree.querySelectorAll('.down-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (selectedElement && selectedElement.nextElementSibling) {
          selectedElement.parentNode?.insertBefore(selectedElement.nextElementSibling, selectedElement);
        }
      });
    });

    domTree.querySelectorAll('.del-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (selectedElement && selectedElement.parentNode) {
          selectedElement.parentNode.removeChild(selectedElement);
          selectElement(null);
        }
      });
    });
  }

  function getElementByPath(path: number[]): HTMLElement | null {
    if (!canvas) return null;
    let target: HTMLElement = canvas;
    for (const idx of path) {
      if (target.children[idx]) {
        target = target.children[idx] as HTMLElement;
      } else {
        return null;
      }
    }
    return target;
  }

  function buildTreeHTML(node: HTMLElement, depth: number, path: number[] = []): string {
    let html = '';
    const children = Array.from(node.children) as HTMLElement[];
    const hasChildren = children.length > 0;
    
    const pathStr = JSON.stringify(path);
    const tagName = node.tagName.toLowerCase();
    const isExpanded = depth === 0 || expandedNodes.has(pathStr) || node === canvas || tagName === 'ppt-container';

    if (node !== canvas) {
      const isSelected = node === selectedElement;
      
      html += `<div class="tree-node-wrapper">`;
      html += `<div class="tree-node-row tree-node-clickable ${isSelected ? 'selected-row' : ''}" data-path='${pathStr}'>`;
      
      // Calculate constraint backgrounds for Tree Node
      const getConstraintBg = (constraints: string[]) => {
        if (!constraints || constraints.length === 0) return 'dashed';
        if (constraints.includes('*')) return '#888';
        const colors = constraints.map((tag: string) => {
          const libItem = document.querySelector(`.library-item[data-tag="${tag.toLowerCase()}"]`);
          if (libItem) {
            const defStr = libItem.getAttribute('data-component-def');
            if (defStr) {
               try { return JSON.parse(defStr).familyColor || '#888'; } catch(e){}
            }
          }
          return '#888';
        });
        if (colors.length === 1) return colors[0];
        return `linear-gradient(to bottom, ${colors.join(', ')})`;
      };
      
      const libItem = document.querySelector(`.library-item[data-tag="${tagName}"]`);
      let compDef: any = null;
      if (libItem) {
        const defStr = libItem.getAttribute('data-component-def');
        if (defStr) {
          try { compDef = JSON.parse(defStr); } catch(e){}
        }
      }
      
      const displayName = compDef?.displayName || `<${tagName}>`;
      const color = compDef?.familyColor || '#888';

      const parentBg = getConstraintBg(compDef?.canNestIn || []);
      const childBg = getConstraintBg(compDef?.acceptsChildren || []);

      html += `<div class="tree-node" data-path='${pathStr}'>`;
      
      html += `<div class="constraint-left ${parentBg === 'dashed' ? 'constraint-dashed' : ''}" style="${parentBg !== 'dashed' ? `background: ${parentBg};` : ''}"></div>`;

      html += `<div class="tree-node-content">
        ${hasChildren && tagName !== 'ppt-container' ? 
          `<button class="tree-toggle" data-path='${pathStr}'>${isExpanded ? '▾' : '▸'}</button>` : 
          `<span class="tree-spacer"></span>`
        }
        <span class="color-swatch" style="background-color: ${color}; width: 10px; height: 10px; display: inline-block; margin-right: 6px; border-radius: 2px;"></span>
        <span class="tag-name" title="${tagName}" style="font-weight: bold; color: #fff;">${displayName}</span>`;
        
      if (!hasChildren && node.textContent && node.textContent.trim().length > 0) {
        let text = node.textContent.trim();
        if (text.length > 15) text = text.substring(0, 15) + '...';
        html += `<span class="content-preview" style="color: #888; font-style: italic; font-weight: normal; margin-left: 8px;">"${text}"</span>`;
      }
      
      html += `</div>`; // Close tree-node-content
      html += `<div class="constraint-right ${childBg === 'dashed' ? 'constraint-dashed' : ''}" style="${childBg !== 'dashed' ? `background: ${childBg};` : ''}"></div>`;
      html += `</div>`; // Close tree-node
      
      if (isSelected) {
         const isFirst = node.previousElementSibling === null;
         const isLast = node.nextElementSibling === null;
         const disableAdd = compDef?.acceptsChildren?.length === 0;
         
         html += `<div class="tree-controls">
           <button class="tree-btn add-btn" title="Add Child" ${disableAdd ? 'disabled' : ''}>
             <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
           </button>
           <button class="tree-btn up-btn" title="Move Up" ${isFirst ? 'disabled' : ''}>
             <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><polygon points="12,6 4,18 20,18"></polygon></svg>
           </button>
           <button class="tree-btn down-btn" title="Move Down" ${isLast ? 'disabled' : ''}>
             <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><polygon points="12,18 4,6 20,6"></polygon></svg>
           </button>
           ${tagName !== 'ppt-container' ? `
           <button class="tree-btn del-btn" title="Delete">
             <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
           </button>
           ` : ''}
         </div>`;
      }
      
      html += `</div>`; // Close tree-node-row
    }

    if (node === canvas || (hasChildren && isExpanded)) {
      html += `<div class="tree-children ${node !== canvas ? 'nested' : ''}">`;
      children.forEach((child, index) => {
        html += buildTreeHTML(child, node === canvas ? 0 : depth + 1, [...path, index]);
      });
      html += `</div>`;
    }
    
    if (node !== canvas) {
      html += `</div>`;
    }

    return html;
  }

  // Drag and Drop Setup
  let draggedTag: string | null = null;

  libraryItems.forEach(item => {
    item.addEventListener('dragstart', (e: any) => {
      draggedTag = item.getAttribute('data-tag');
      e.dataTransfer.setData('text/plain', draggedTag);
      e.dataTransfer.effectAllowed = 'copy';
      toggleDrawer(false); // Close drawer while dragging
    });
  });

  // Canvas drag and drop removed
  // We only allow dropping onto the tree or the tree root.
</script>

