---
import { getPPTComponents } from './parseComponents.js';

const components = getPPTComponents();
---

<div class="designer-app">
  <!-- Left Pane: Library & Tree -->
  <aside class="pane pane-left">
    <div class="pane-header">Library</div>
    <div class="pane-content">
      <ul class="component-library" id="library-list">
        {components.map(comp => (
          <li class="library-item" draggable="true" data-tag={comp.tagName} data-attributes={JSON.stringify(comp.attributes)}>
            <span class="tag-name">&lt;{comp.tagName}&gt;</span>
          </li>
        ))}
      </ul>
      
      <div class="pane-header" style="margin-top: 1rem;">DOM Tree</div>
      <div class="pane-content tree-view" id="dom-tree">
        <!-- Tree populated dynamically -->
      </div>
    </div>
  </aside>

  <!-- Center Pane: Canvas -->
  <main class="pane pane-center">
    <div class="pane-header">Live Preview Canvas</div>
    <div class="canvas-wrapper" id="canvas-wrapper">
      <div class="canvas" id="canvas">
        <!-- Components are dropped here -->
        <ppt-period id="demo-period" shape="circle" interactive="true" min-width="200" min-height="200" style="width: 300px; height: 300px; margin: 0 auto;">
          <ppt-period-step-circle slot="step">A</ppt-period-step-circle>
          <ppt-period-step-circle slot="step">B</ppt-period-step-circle>
          <ppt-period-step-circle slot="step">C</ppt-period-step-circle>
        </ppt-period>
      </div>
    </div>
  </main>

  <!-- Right Pane: Properties -->
  <aside class="pane pane-right">
    <div class="pane-header">Properties</div>
    <div class="pane-content" id="properties-panel">
      <p class="empty-state">Select a component to edit its properties.</p>
    </div>
  </aside>

  <!-- Bottom Pane: Source Code -->
  <footer class="pane pane-bottom">
    <div class="pane-header">Source Code (HTML)</div>
    <div class="pane-content">
      <pre><code id="source-code"></code></pre>
    </div>
  </footer>
</div>

<script>
  // State
  let selectedElement: HTMLElement | null = null;
  const canvas = document.getElementById('canvas');
  const domTree = document.getElementById('dom-tree');
  const propertiesPanel = document.getElementById('properties-panel');
  const sourceCode = document.getElementById('source-code');
  const libraryItems = document.querySelectorAll('.library-item');

  // Initial code sync
  function syncCode() {
    if (!canvas || !sourceCode) return;
    
    // Simple formatter to add some line breaks
    let html = canvas.innerHTML
      .replace(/></g, '>\n  <')
      .trim();
    
    // Ensure standard angle brackets
    sourceCode.textContent = html;
  }

  // MutationObserver for live code sync
  if (canvas) {
    const observer = new MutationObserver(() => {
      syncCode();
      renderTree();
    });
    observer.observe(canvas, { childList: true, subtree: true, attributes: true });
    syncCode();
    renderTree();
  }

  // Handle Selection
  if (canvas) {
    canvas.addEventListener('click', (e) => {
      e.stopPropagation(); // prevent bubbling to canvas container
      
      const target = e.target as HTMLElement;
      if (target === canvas) {
        selectElement(null);
      } else {
        selectElement(target);
      }
    });
  }

  function selectElement(el: HTMLElement | null) {
    // Clear previous selection
    if (selectedElement) {
      selectedElement.classList.remove('designer-selected');
    }
    
    selectedElement = el;
    
    if (selectedElement) {
      selectedElement.classList.add('designer-selected');
      renderProperties(selectedElement);
    } else {
      renderProperties(null);
    }
    renderTree(); // Highlight in tree
  }

  // Render Properties Panel
  function renderProperties(el: HTMLElement | null) {
    if (!propertiesPanel) return;
    
    if (!el) {
      propertiesPanel.innerHTML = '<p class="empty-state">Select a component to edit its properties.</p>';
      return;
    }

    const tagName = el.tagName.toLowerCase();
    
    // Find attributes from the library items data-attributes map
    let allowedAttrs: string[] = [];
    const libItem = document.querySelector(`.library-item[data-tag="${tagName}"]`);
    if (libItem) {
      allowedAttrs = JSON.parse(libItem.getAttribute('data-attributes') || '[]');
    }

    // Common HTML attributes that we always allow editing
    const commonAttrs = ['id', 'class', 'style', 'slot'];
    const allAttrs = [...new Set([...commonAttrs, ...allowedAttrs])];

    let html = `<h3>&lt;${tagName}&gt;</h3><div class="prop-form">`;
    
    allAttrs.forEach(attr => {
      const val = el.getAttribute(attr) || '';
      // We could render sliders for numbers or selects for shapes, but text inputs are a good v1
      html += `
        <div class="prop-group">
          <label>${attr}</label>
          <input type="text" data-attr="${attr}" value="${val.replace(/"/g, '&quot;')}" />
        </div>
      `;
    });
    
    html += '</div>';
    
    html += `
      <div class="prop-actions" style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #ddd;">
        <button id="btn-delete" class="danger-btn">Delete Component</button>
      </div>
    `;

    propertiesPanel.innerHTML = html;

    // Attach listeners to inputs
    const inputs = propertiesPanel.querySelectorAll('input');
    inputs.forEach(input => {
      input.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        const attr = target.getAttribute('data-attr');
        if (attr) {
          if (target.value) {
            el.setAttribute(attr, target.value);
          } else {
            el.removeAttribute(attr);
          }
        }
      });
    });

    // Delete button
    const delBtn = propertiesPanel.querySelector('#btn-delete');
    if (delBtn) {
      delBtn.addEventListener('click', () => {
        if (el && el.parentNode) {
          el.parentNode.removeChild(el);
          selectElement(null);
        }
      });
    }
  }

  // Render DOM Tree
  function renderTree() {
    if (!domTree || !canvas) return;
    
    domTree.innerHTML = buildTreeHTML(canvas, 0);
    
    // Attach tree listeners
    const treeItems = domTree.querySelectorAll('.tree-node');
    treeItems.forEach(item => {
      item.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = item.getAttribute('data-node-id');
        // Simple way to map tree back to DOM element: adding a temporary id if needed, 
        // or just re-traversing. For simplicity, we just look up by a path or reference.
        // As a hack for v1, we can just walk the DOM the exact same way.
        const pathStr = item.getAttribute('data-path');
        if (pathStr) {
          const path = JSON.parse(pathStr);
          let target: any = canvas;
          for (const idx of path) {
             target = target.children[idx];
          }
          if (target) {
            selectElement(target);
          }
        }
      });
    });
  }

  function buildTreeHTML(node: HTMLElement, depth: number, path: number[] = []): string {
    let html = '';
    const children = Array.from(node.children) as HTMLElement[];
    
    if (node !== canvas) {
      const isSelected = node === selectedElement;
      html += `<div class="tree-node ${isSelected ? 'selected' : ''}" style="padding-left: ${depth * 10}px" data-path="${JSON.stringify(path)}">`;
      html += `&lt;${node.tagName.toLowerCase()}&gt;`;
      if (node.id) html += ` <span class="tree-id">#${node.id}</span>`;
      html += `</div>`;
    }

    children.forEach((child, index) => {
      html += buildTreeHTML(child, node === canvas ? 0 : depth + 1, [...path, index]);
    });

    return html;
  }

  // Drag and Drop (Library -> Canvas)
  let draggedTag: string | null = null;

  libraryItems.forEach(item => {
    item.addEventListener('dragstart', (e: any) => {
      draggedTag = item.getAttribute('data-tag');
      e.dataTransfer.setData('text/plain', draggedTag);
      e.dataTransfer.effectAllowed = 'copy';
    });
  });

  if (canvas) {
    canvas.addEventListener('dragover', (e) => {
      e.preventDefault(); // Necessary to allow dropping
      e.dataTransfer!.dropEffect = 'copy';
    });

    canvas.addEventListener('drop', (e) => {
      e.preventDefault();
      if (!draggedTag) return;

      const newEl = document.createElement(draggedTag);
      
      // If we drop on an existing element inside the canvas, append to it, otherwise append to canvas
      let target = e.target as HTMLElement;
      // Don't append to canvas if we drop strictly outside the container logic, but here canvas is the container
      
      // Ensure we only drop into elements that support children, like ppt-period.
      if (target.tagName.toLowerCase().includes('ppt-')) {
         // Default to slot="step" for dropping into PPT components if it's a step circle
         if (draggedTag === 'ppt-period-step-circle') {
            newEl.setAttribute('slot', 'step');
         }
         target.appendChild(newEl);
      } else {
         canvas.appendChild(newEl);
      }

      selectElement(newEl);
      draggedTag = null;
    });
  }
</script>

<style>
  .designer-app {
    display: grid;
    grid-template-columns: 250px 1fr 300px;
    grid-template-rows: 1fr 200px;
    height: 100%;
    width: 100%;
    background: #1e1e1e;
    color: #d4d4d4;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    overflow: hidden;
  }

  .pane {
    display: flex;
    flex-direction: column;
    border: 1px solid #333;
    background: #252526;
    overflow: hidden;
  }

  .pane-header {
    background: #2d2d2d;
    padding: 8px 12px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    color: #cccccc;
    border-bottom: 1px solid #333;
    user-select: none;
  }

  .pane-content {
    flex: 1;
    overflow-y: auto;
    padding: 12px;
  }

  /* Grid areas */
  .pane-left { grid-column: 1; grid-row: 1; }
  .pane-center { grid-column: 2; grid-row: 1; background: #1e1e1e; }
  .pane-right { grid-column: 3; grid-row: 1; }
  .pane-bottom { grid-column: 1 / -1; grid-row: 2; }

  /* Library */
  .component-library {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .library-item {
    padding: 8px;
    background: #333;
    margin-bottom: 8px;
    border-radius: 4px;
    cursor: grab;
    font-family: monospace;
    font-size: 13px;
    border: 1px solid #444;
  }
  
  .library-item:active {
    cursor: grabbing;
  }

  .library-item:hover {
    background: #444;
  }

  /* Tree View */
  .tree-node {
    font-family: monospace;
    font-size: 13px;
    padding: 4px;
    cursor: pointer;
    white-space: nowrap;
    border-radius: 3px;
  }
  .tree-node:hover {
    background: #333;
  }
  .tree-node.selected {
    background: #094771;
    color: #fff;
  }
  .tree-id {
    color: #ce9178;
  }

  /* Canvas */
  .canvas-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: auto;
    padding: 2rem;
    /* Checkerboard pattern */
    background-color: #e5e5f7;
    background-image:  repeating-linear-gradient(45deg, #d4d4d4 25%, transparent 25%, transparent 75%, #d4d4d4 75%, #d4d4d4), repeating-linear-gradient(45deg, #d4d4d4 25%, #e5e5f7 25%, #e5e5f7 75%, #d4d4d4 75%, #d4d4d4);
    background-position: 0 0, 10px 10px;
    background-size: 20px 20px;
  }
  
  .canvas {
    background: #fff;
    width: 100%;
    min-height: 500px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    position: relative;
    color: #000;
  }

  /* Properties */
  .empty-state {
    color: #888;
    font-style: italic;
    font-size: 13px;
  }
  
  .prop-form h3 {
    margin-top: 0;
    font-size: 14px;
    color: #fff;
    font-family: monospace;
  }
  
  .prop-group {
    margin-bottom: 12px;
    display: flex;
    flex-direction: column;
  }
  
  .prop-group label {
    font-size: 11px;
    margin-bottom: 4px;
    color: #aaa;
  }
  
  .prop-group input {
    background: #3c3c3c;
    border: 1px solid #555;
    color: #fff;
    padding: 6px;
    border-radius: 2px;
    font-family: monospace;
  }
  
  .prop-group input:focus {
    outline: none;
    border-color: #007fd4;
  }

  .danger-btn {
    background: #8a1a1a;
    color: white;
    border: none;
    padding: 6px 12px;
    border-radius: 3px;
    cursor: pointer;
    font-size: 12px;
    width: 100%;
  }
  .danger-btn:hover {
    background: #a31d1d;
  }

  /* Source Code */
  .pane-bottom pre {
    margin: 0;
    font-family: monospace;
    font-size: 13px;
    color: #9cdcfe;
    white-space: pre-wrap;
  }

  /* Canvas Selection Outline (injected globally via ID to avoid scoping issues with web components inside canvas) */
</style>
<style is:global>
  /* Inject standard web components into page for preview to work */
  .designer-selected {
    outline: 2px solid #007fd4 !important;
    outline-offset: 2px;
  }
</style>
