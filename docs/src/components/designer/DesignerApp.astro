<style is:global>
  /* Syntax Highlighting */
  .hl-tag { color: #569cd6; }
  .hl-attr { color: #9cdcfe; }
  .hl-val { color: #ce9178; }
  .hl-comment { color: #6a9955; }

  .constraint-left, .constraint-right {
    position: absolute;
    top: 0; bottom: 0;
    width: 4px;
  }
  .constraint-left { left: 0; }
  .constraint-right { right: 0; }

  .constraint-dashed {
    background: transparent !important;
    border-right: 1px dashed #777;
    width: 1px;
  }
  .constraint-left.constraint-dashed { left: 3px; border-right: none; border-left: 1px dashed #777; }
  .constraint-right.constraint-dashed { right: 3px; }

  /* Context Menu */
  .context-menu {
    position: absolute;
    background: #2d2d2d;
    border: 1px solid #444;
